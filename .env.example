# Copy to .env on the VPS, then fill the values.
# Never commit the real .env.

# Public hostname that points to the VPS.
PUBLIC_DOMAIN=ai.example.com
PUBLIC_BASE_URL=https://ai.example.com
ADMIN_EMAIL=admin@example.com

# Public web server mode.
# caddy: repo manages Caddy on ports 80/443.
# nginx-direct: existing Nginx handles TLS/public traffic and proxies directly
# to 9Router at http://127.0.0.1:20128. In this mode, skip Caddy setup.
WEB_SERVER=nginx-direct

# 9Router dashboard/security.
NINE_ROUTER_INITIAL_PASSWORD=change-this-long-random-password
NINE_ROUTER_JWT_SECRET=change-this-64-char-random-secret
NINE_ROUTER_API_KEY_SECRET=change-this-64-char-random-secret
NINE_ROUTER_MACHINE_ID_SALT=change-this-64-char-random-secret

# API key generated from the 9Router dashboard after provider setup.
# Hermes uses this to call https://PUBLIC_DOMAIN/v1.
NINE_ROUTER_API_KEY=
NINE_ROUTER_BASE_URL=https://ai.example.com/v1

# Model alias/combo configured inside 9Router.
# Recommended: create an alias or combo named orchestrator/powerful
# that routes to your strongest model first and falls back automatically.
HERMES_MODEL=orchestrator/powerful

# Discord bot token for Hermes gateway (legacy single-bot mode).
DISCORD_BOT_TOKEN=

# Per-profile Discord bot tokens (multi-agent mode).
# Each profile gets its own Discord bot for channel isolation.
DISCORD_BOT_TOKEN_ORCHESTRATOR=
DISCORD_BOT_TOKEN_RESEARCHER=
DISCORD_BOT_TOKEN_EXECUTOR=

# Runtime identities.
HERMES_USER=hermes
HERMES_AGENT_NAME=hermes-orchestrator
