# ============================================================================
# Hermes Orchestrator — Environment Variables
# ============================================================================
#
# Skills to pre-install for this profile:
#
#   Shared (read-only, symlinked from /var/lib/morph-agency/skills/common/):
#     - git-workflow.md          Git branching, commit conventions, PR workflow
#     - code-standards.md        Coding style, naming, formatting rules
#     - security-checklist.md    Pre-commit security verification checklist
#
#   Profile-specific (~/.hermes/profiles/orchestrator/skills/):
#     - task-decomposition.md    Patterns for breaking requests into subtasks
#     - delegation-protocol.md   How to route tasks to researcher/executor
#     - synthesis-patterns.md    Merging partial results into final deliverable
#     - priority-triage.md       Urgency assessment and task ordering rules
#     - failure-escalation.md    When and how to escalate failed subtasks
#
# ============================================================================

# 9Router LLM Gateway — shared across all profiles, same instance.
# Generate the API key from the 9Router dashboard after provider setup.
NINE_ROUTER_API_KEY=
NINE_ROUTER_BASE_URL=https://ai.example.com/v1

# Discord bot token — UNIQUE per profile. Create a separate bot application
# for the orchestrator at https://discord.com/developers/applications.
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to interact with this bot.
# Leave empty to allow all server members (not recommended for production).
DISCORD_ALLOWED_USERS=

# Runtime identity (must match agent.name in config.yaml).
HERMES_AGENT_NAME=hermes-orchestrator
