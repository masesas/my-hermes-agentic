# ============================================================================
# Hermes Executor — Environment Variables
# ============================================================================
#
# Skills to pre-install for this profile:
#
#   Shared (read-only, symlinked from /var/lib/morph-agency/skills/common/):
#     - git-workflow.md          Git branching, commit conventions, PR workflow
#     - code-standards.md        Coding style, naming, formatting rules
#     - security-checklist.md    Pre-commit security verification checklist
#
#   Profile-specific (~/.hermes/profiles/executor/skills/):
#     - tdd-workflow.md          Test-driven development: red-green-refactor
#     - build-troubleshooting.md Diagnosing and fixing build/test failures
#     - file-operations.md       Safe file creation, modification, deletion
#     - git-operations.md        Branch management, commit, push conventions
#     - code-quality-gates.md    Lint, typecheck, coverage thresholds
#
# ============================================================================

# 9Router LLM Gateway — shared across all profiles, same instance.
# Generate the API key from the 9Router dashboard after provider setup.
NINE_ROUTER_API_KEY=
NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/api/v1
HERMES_MODEL=morph-executor

# Discord bot token — UNIQUE per profile. Create a separate bot application
# for the executor at https://discord.com/developers/applications.
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to interact with this bot.
# WARNING: empty does NOT always mean allow-all. Some Hermes gateway versions
# treat empty as deny-all. Always set explicit user IDs for production.
DISCORD_ALLOWED_USERS=

# Comma-separated Discord channel IDs where this bot is the OWNER (default responder
# for un-mentioned human messages). The bot can still be @mentioned in any channel.
# Caveat: this is honored only if the Hermes Discord gateway implements the owner-channel
# filter. If the gateway ignores this variable, rely on the SOUL silence rules instead.
#
# Recommended: set to the Discord channel ID of #executor after smoke testing.
# Leave empty to skip hard enforcement and rely only on SOUL guardrails.
DISCORD_OWNER_CHANNELS=

# Runtime identity (must match agent.name in config.yaml).
HERMES_AGENT_NAME=hermes-executor
HERMES_PROFILE=executor
MORPH_AGENCY_DIR=/var/lib/morph-agency
MORPH_AUTONOMOUS_MODE=orchestrated
MORPH_ROUTING_POLICY=/var/lib/morph-agency/config/autonomous-routing.yaml
MORPH_DISCORD_POLICY=/home/hermes/.hermes/profiles/executor/discord-policy.yaml
